#!/bin/bash
///bin/sleep 0; exec java -Dapple.awt.UIElement=true --source 11 "$0" "$@"

import java.awt.MouseInfo;
import java.awt.Point;
import java.awt.Robot;

public class Awake {
    private static long initialTime;
    private static long duration;
    private static boolean silent;

    public static void main(String[] args) throws Exception {
        initialTime = System.currentTimeMillis();
        duration = 0;
        silent = false;

        int hours = 0, minutes = 0, seconds = 0;
        for (int i = 0; i < args.length; i++) {
            switch (args[i]) {
                case "--hours": case "-H":
                    hours = Integer.parseInt(args[++i]);
                    break;
                case "--minutes": case "-M":
                    minutes = Integer.parseInt(args[++i]);
                    break;
                case "--seconds": case "-S":
                    seconds = Integer.parseInt(args[++i]);
                    break;
                case "--silent": case "-s":
                    silent = true;
                    break;
                case "--help": case "-h":
                    printHelp();
                    System.exit(0);
                    break;
                default:
                    System.err.println("Unknown argument: " + args[i]);
                    printHelp();
                    System.exit(1);
            }
        }

        if (hours == 0 && minutes == 0 && seconds == 0) {
            duration = 0;
            log("Running indefinitely");
        } else {
            duration = hours * 3600L + minutes * 60L + seconds;
            log("Running for: " + formatDuration(duration));
        }

        Runtime.getRuntime().addShutdownHook(new Thread(() -> {
            updateTime(System.currentTimeMillis());
            log("");
        }));

        Robot robot = new Robot();
        robot.setAutoWaitForIdle(true);
        Point lastLocation = MouseInfo.getPointerInfo().getLocation();
        long lastTime = System.currentTimeMillis();
        updateTime(lastTime);

        while (true) {
            long currentTime = System.currentTimeMillis();
            updateTime(currentTime);

            if (duration != 0 && currentTime >= duration * 1000 + initialTime) {
                System.exit(0);
            }

            if (currentTime >= lastTime + 10000) {
                Point currentLocation = MouseInfo.getPointerInfo().getLocation();
                if (lastLocation.equals(currentLocation)) {
                    int x = (int) currentLocation.getX();
                    int y = (int) currentLocation.getY();
                    robot.mouseMove(x + 1, y + 1);
                    robot.mouseMove(x, y);
                }
                lastLocation = currentLocation;
                lastTime = currentTime;
            }

            Thread.sleep(500);
        }
    }

    private static String formatDuration(long totalSeconds) {
        long h = totalSeconds / 3600;
        long m = (totalSeconds % 3600) / 60;
        long s = totalSeconds % 60;
        return String.format("%02d:%02d:%02d", h, m, s);
    }

    private static void updateTime(long currentTime) {
        if (!silent) {
            long elapsed = (currentTime - initialTime) / 1000;
            System.out.print("\rAwake for: " + formatDuration(elapsed));
            System.out.flush();
        }
    }

    private static void log(String s) {
        if (!silent) {
            System.out.println(s);
        }
    }

    private static void printHelp() {
        System.out.println("usage: awake [-h] [--hours HOURS] [--minutes MINUTES] [--seconds SECONDS] [--silent]");
        System.out.println();
        System.out.println("Keeps your computer awake using tiny mouse movements");
        System.out.println("Runs indefinitely by default but may be provided a specific amount of time to lapse");
        System.out.println();
        System.out.println("options:");
        System.out.println("  -h, --help            show this help message and exit");
        System.out.println("  --hours HOURS, -H HOURS");
        System.out.println("                        number of hours");
        System.out.println("  --minutes MINUTES, -M MINUTES");
        System.out.println("                        number of minutes");
        System.out.println("  --seconds SECONDS, -S SECONDS");
        System.out.println("                        number of seconds");
        System.out.println("  --silent, -s");
    }
}
